# Copy this file to .env.production on the VM and fill in all values
# cp .env.production.example .env.production

NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://wallo.cc
LOG_LEVEL=warn

# MongoDB
MONGODB_URI=

# Auth
JWT_SECRET=

# Redis — keep this exactly as-is (points to the Docker redis service)
REDIS_URL=redis://redis:6379

# Storage namespace — prefixes all R2 keys (exports/<env>/…) and Cloudinary
# folders (<env>/…) so dev and prod never collide in a shared bucket/cloud.
# Use 'prod' in production; defaults to 'dev' locally.
STORAGE_ENV=prod

# Painter invite-link lifetime in days (Phase B). Defaults to 30 if unset.
INVITE_TTL_DAYS=30

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase (server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Admin
ADMIN_CONTACT_EMAIL=
NEXT_PUBLIC_ADMIN_CONTACT_EMAIL=
